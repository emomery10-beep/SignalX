{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "pos-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "pos-askbiz", "run", "dev"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "next-dev-verify",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3050,
      "autoPort": true
    },
    {
      "name": "pos-prod-verify",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "pos-askbiz", "run", "start"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "next-prod-verify",
      "runtimeExecutable": "env",
      "runtimeArgs": ["CLAUDE_VERIFY_DIST_DIR=.next-verify", "npx", "next", "start", "-p", "3060"],
      "port": 3060,
      "autoPort": true
    },
    {
      "name": "developers-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "developers-askbiz", "run", "dev"],
      "port": 3002,
      "autoPort": true
    }
  ]
}
