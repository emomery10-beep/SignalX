

# ── SHOPIFY OAuth ─────────────────────────────────────────────
NEXT_PUBLIC_SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=
# Redirect: https://askbiz.co/api/auth/shopify/callback
# Shopify partner portal: https://partners.shopify.com

# ── AMAZON SP-API ─────────────────────────────────────────────
AMAZON_APP_ID=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
# Register at: https://sellercentral.amazon.com/apps/registered
# Redirect: https://askbiz.co/api/auth/amazon/callback

# ── QUICKBOOKS OAuth ──────────────────────────────────────────
NEXT_PUBLIC_QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_SANDBOX=false
# Register at: https://developer.intuit.com/app/developer/myapps
# Redirect: https://askbiz.co/api/auth/quickbooks/callback

# ── GOOGLE OAuth ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Register at: https://console.cloud.google.com/apis/credentials
# Enabled APIs: Google Sheets API, Google Drive API
# Redirect: https://askbiz.co/api/auth/google/callback

# ── STRIPE CONNECT ────────────────────────────────────────────
STRIPE_CLIENT_ID=

# ── TIKTOK SHOP Partner API ────────────────────────────────────
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
# Register at: https://partner.tiktokshop.com
# Redirect must be set in the app's Partner Center settings to:
# https://askbiz.co/api/auth/tiktok-shop/callback

# ── META (Meta Ads + Instagram Shopping) OAuth ─────────────────
META_APP_ID=
META_APP_SECRET=
# Register at: https://developers.facebook.com/apps
# Redirects:
#   https://askbiz.co/api/auth/meta/callback
#   https://askbiz.co/api/auth/instagram-shopping/callback
# Meta Ads only needs ads_read/read_insights/business_management (Standard Access).
# Instagram Shopping additionally needs catalog_management, commerce_account_read_orders,
# commerce_account_read_settings, instagram_shopping_tag_products — these require
# Meta Business Verification + App Review (Advanced Access) before real merchant
# orders are reachable. Until approved, the app can only read test commerce accounts.

# Tavily Web Search — primary market signal source (https://tavily.com)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Serper.dev — Google Search fallback when Tavily returns no data (https://serper.dev)
SERPER_API_KEY=your-serper-key-here

# Cron secret (set in Vercel env vars — any random string)
CRON_SECRET=your-secret-here

# Supabase service role key (for agent DB writes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend email API (get from resend.com — free tier sends 3,000 emails/month)
RESEND_API_KEY=re_your_key_here

# ── PESAPAL v3 (Kenya payments — M-Pesa, Airtel Money, cards) ─
# Register at: https://developer.pesapal.com
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENV=sandbox
PESAPAL_CALLBACK_URL=https://askbiz.co/api/pesapal/callback
