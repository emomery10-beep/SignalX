

# ── SHOPIFY OAuth ─────────────────────────────────────────────
NEXT_PUBLIC_SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=
# Redirect: https://askbiz.co/api/auth/shopify/callback
# Shopify partner portal: https://partners.shopify.com

# ── AMAZON SP-API ─────────────────────────────────────────────
NEXT_PUBLIC_AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
# Register at: https://sellercentral.amazon.com/apps/registered
# Redirect: https://askbiz.co/api/auth/amazon/callback

# ── QUICKBOOKS OAuth ──────────────────────────────────────────
NEXT_PUBLIC_QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_SANDBOX=false
# Register at: https://developer.intuit.com/app/developer/myapps
# Redirect: https://askbiz.co/api/auth/quickbooks/callback

# ── GOOGLE OAuth ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Register at: https://console.cloud.google.com/apis/credentials
# Enabled APIs: Google Sheets API, Google Drive API
# Redirect: https://askbiz.co/api/auth/google/callback

# ── SHOPIFY OAUTH ────────────────────────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# ── AMAZON SP-API ────────────────────────────────────────────
AMAZON_APP_ID=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=

# ── STRIPE CONNECT ────────────────────────────────────────────
STRIPE_CLIENT_ID=
# STRIPE_SECRET_KEY already set above

# ── QUICKBOOKS OAUTH ─────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# ── GOOGLE OAUTH ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Tavily Web Search (https://tavily.com — already added to Vercel)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Cron secret (set in Vercel env vars — any random string)
CRON_SECRET=your-secret-here

# Supabase service role key (for agent DB writes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend email API (get from resend.com — free tier sends 3,000 emails/month)
RESEND_API_KEY=re_your_key_here
