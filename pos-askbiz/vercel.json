{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "ignoreCommand": "git diff --quiet ${VERCEL_GIT_PREVIOUS_SHA:-HEAD^} HEAD -- pos-askbiz",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "main": true
    }
  },
  "crons": [
    { "path": "/api/cron/restaurant-brief", "schedule": "30 23 * * *" },
    { "path": "/api/agent", "schedule": "0 6 * * *" }
  ]
}
