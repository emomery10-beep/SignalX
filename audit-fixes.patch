--- /dev/null
+++ b/supabase/migrations/013_admin_rbac.sql
@@ -0,0 +1,22 @@
+-- ============================================================
+-- Admin RBAC — replace hardcoded email checks with a DB flag
+-- ============================================================
+
+alter table public.profiles
+  add column if not exists is_admin boolean not null default false;
+
+create index if not exists idx_profiles_is_admin
+  on public.profiles(is_admin)
+  where is_admin = true;
+
+-- Seed existing admins from auth.users so access is preserved
+update public.profiles p
+set is_admin = true
+from auth.users u
+where p.id = u.id
+  and lower(u.email) in ('emomery10@gmail.com', 'emomery10@googlemail.com');
+
+-- Allow users to read their own admin flag (already covered by
+-- "Users can view own profile" but kept explicit for clarity).
+-- No policy is added that would let a user *grant* themselves admin —
+-- only the service role (or a manual SQL update) can flip is_admin.
